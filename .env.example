# PostgreSQL used by the server and by Docker Compose
POSTGRES_DB=relaydock
POSTGRES_USER=relaydock
POSTGRES_PASSWORD=change-this-local-password
RELAYDOCK_POSTGRES_PORT=5432
DATABASE_URL=postgresql://relaydock:change-this-local-password@localhost:5432/relaydock?schema=public

# Server
NODE_ENV=development
RELAYDOCK_HOST=0.0.0.0
RELAYDOCK_PORT=3000
RELAYDOCK_WEB_ORIGIN=http://localhost:5173
RELAYDOCK_ALLOW_REGISTRATION=true
RELAYDOCK_SESSION_TTL_HOURS=168
RELAYDOCK_PAIRING_CODE_TTL_MINUTES=10
RELAYDOCK_HEARTBEAT_INTERVAL_MS=15000
RELAYDOCK_OFFLINE_AFTER_MS=45000
RELAYDOCK_JOB_RETENTION_DAYS=30
RELAYDOCK_MAX_JOB_OUTPUT_BYTES=10485760
RELAYDOCK_LOG_LEVEL=info

# Generate independent values with: openssl rand -hex 32
RELAYDOCK_SESSION_PEPPER=replace-with-at-least-32-random-characters
RELAYDOCK_CREDENTIAL_PEPPER=replace-with-another-32-random-characters
