{
  "name": "@relaydock/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file-if-exists=../../.env --watch --import tsx src/index.ts",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "node --env-file-if-exists=../../.env node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node --env-file-if-exists=../../.env node_modules/prisma/build/index.js migrate dev",
    "prisma:deploy": "node --env-file-if-exists=../../.env node_modules/prisma/build/index.js migrate deploy"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^6.19.0",
    "@relaydock/config": "workspace:*",
    "@relaydock/protocol": "workspace:*",
    "@relaydock/shared": "workspace:*",
    "argon2": "^0.44.0",
    "fastify": "^5.6.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
