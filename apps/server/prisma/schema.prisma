generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeviceStatus {
  online
  offline
  revoked
}

enum JobStatus {
  queued
  dispatched
  running
  waiting_for_input
  completed
  failed
  cancelled
  disconnected
}

enum OutputStream {
  stdout
  stderr
  system
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique @db.VarChar(320)
  // Null for accounts created through an identity provider (e.g. Google) that
  // have never set a local password.
  passwordHash String?
  // Stable Google subject identifier for accounts linked to Google sign-in.
  googleSub    String?       @unique @db.VarChar(255)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  devices      Device[]
  pairingCodes PairingCode[]
  jobs         Job[]
  auditEvents  AuditEvent[]
}

model Session {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  tokenHash     String    @unique @db.Char(64)
  csrfTokenHash String    @db.Char(64)
  expiresAt     DateTime
  lastUsedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Device {
  id           String             @id @default(uuid()) @db.Uuid
  userId       String             @db.Uuid
  name         String             @db.VarChar(100)
  platform     String             @db.VarChar(50)
  architecture String             @db.VarChar(50)
  agentVersion String             @db.VarChar(50)
  status       DeviceStatus       @default(offline)
  lastSeenAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials  DeviceCredential[]
  repositories Repository[]
  jobs         Job[]
  auditEvents  AuditEvent[]

  @@index([userId])
  @@index([status, lastSeenAt])
}

model DeviceCredential {
  id             String    @id @default(uuid()) @db.Uuid
  deviceId       String    @db.Uuid
  credentialHash String    @unique @db.Char(64)
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  device         Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model PairingCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  codeHash  String    @unique @db.Char(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Repository {
  id                   String   @id @default(uuid()) @db.Uuid
  deviceId             String   @db.Uuid
  name                 String   @db.VarChar(100)
  absolutePath         String   @db.VarChar(4096)
  description          String?  @db.VarChar(1000)
  enabled              Boolean  @default(false)
  allowCustomCommands  Boolean  @default(false)
  shell                String   @default("/bin/zsh") @db.VarChar(4096)
  shellArgs            Json
  inheritedEnvironment Json
  isGitRepository      Boolean?
  branch               String?  @db.VarChar(500)
  repositoryRoot       String?  @db.VarChar(4096)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  device               Device   @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  actions              Action[]
  jobs                 Job[]

  @@unique([deviceId, absolutePath])
  @@index([deviceId])
}

model Action {
  id                   String     @id @default(uuid()) @db.Uuid
  repositoryId         String     @db.Uuid
  name                 String     @db.VarChar(100)
  command              String     @db.VarChar(16384)
  workingDirectory     String     @default("") @db.VarChar(4096)
  interactive          Boolean    @default(false)
  persistent           Boolean    @default(false)
  confirmationRequired Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  repository           Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  jobs                 Job[]

  @@index([repositoryId])
}

model Job {
  id                  String           @id @default(uuid()) @db.Uuid
  userId              String           @db.Uuid
  deviceId            String           @db.Uuid
  repositoryId        String           @db.Uuid
  actionId            String?          @db.Uuid
  command             String           @db.VarChar(16384)
  workingDirectory    String           @default("") @db.VarChar(4096)
  status              JobStatus        @default(queued)
  interactive         Boolean          @default(false)
  persistent          Boolean          @default(false)
  exitCode            Int?
  statusDetail        String?          @db.VarChar(2000)
  retainedOutputBytes Int              @default(0)
  outputTruncated     Boolean          @default(false)
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  user                User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  device              Device           @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  repository          Repository       @relation(fields: [repositoryId], references: [id], onDelete: Restrict)
  action              Action?          @relation(fields: [actionId], references: [id], onDelete: SetNull)
  outputChunks        JobOutputChunk[]

  @@index([userId, createdAt])
  @@index([deviceId, status])
  @@index([repositoryId, createdAt])
}

model JobOutputChunk {
  id         String       @id @default(uuid()) @db.Uuid
  jobId      String       @db.Uuid
  sequence   Int
  stream     OutputStream
  data       String
  byteLength Int
  timestamp  DateTime     @default(now())
  job        Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, sequence])
  @@index([jobId, timestamp])
}

model AuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  deviceId  String?  @db.Uuid
  action    String   @db.VarChar(100)
  ipAddress String?  @db.VarChar(100)
  userAgent String?  @db.VarChar(500)
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  device    Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([deviceId, createdAt])
  @@index([action, createdAt])
}
