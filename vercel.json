{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "vite",
      "buildCommand": "cd ../.. && pnpm --filter @relaydock/protocol build && pnpm --filter @relaydock/web build",
      "outputDirectory": "dist",
      "rewrites": [
        {
          "source": "/(.*)",
          "destination": "/index.html"
        }
      ]
    },
    "api": {
      "root": "apps/server",
      "framework": "fastify",
      "entrypoint": "src/vercel.ts",
      "buildCommand": "cd ../.. && pnpm prisma:generate && pnpm --filter @relaydock/protocol build && pnpm --filter @relaydock/config build && pnpm --filter @relaydock/shared build",
      "functions": {
        "src/vercel.ts": {
          "maxDuration": 300
        }
      }
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "api"
      }
    },
    {
      "source": "/ws/(.*)",
      "destination": {
        "service": "api"
      }
    },
    {
      "source": "/health",
      "destination": {
        "service": "api"
      }
    },
    {
      "source": "/ready",
      "destination": {
        "service": "api"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ],
  "headers": [
    {
      "source": "/install-agent.sh",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/downloads/agent/v(.*)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/internal/maintenance",
      "schedule": "0 3 * * *"
    }
  ]
}
